---
interface Props {
  car: {
    id: number;
    title: string;
    price: string;
    km: string;
    status: string;
    image: string;
  };
}

const { car } = Astro.props;
---

<article class="group rounded-2xl border border-zinc-800 bg-zinc-900/40 overflow-hidden hover:border-zinc-700 transition-colors duration-300">
  <div class="relative h-64 overflow-hidden">
    <img 
      src={car.image} 
      alt={car.title} 
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute top-4 right-4 bg-zinc-950/80 backdrop-blur text-brand px-3 py-1 rounded-full text-sm font-semibold border border-brand/20">
      {car.status}
    </div>
  </div>
  
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2 text-zinc-100 group-hover:text-brand transition-colors">{car.title}</h3>
    
    <div class="flex items-center gap-4 text-sm text-zinc-400 mb-6 border-b border-zinc-800/50 pb-4">
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        {car.km}
      </div>
    </div>
    
    <div class="flex items-center justify-between">
      <span class="text-2xl font-bold text-zinc-100">{car.price}</span>
      <a href={`/contacto?car=${car.id}`} class="bg-brand text-zinc-950 px-5 py-2.5 rounded-xl font-semibold shadow-[0_0_15px_rgba(34,197,94,0.3)] hover:shadow-[0_0_25px_rgba(34,197,94,0.5)] hover:scale-105 transition-all duration-300">
        Me interesa
      </a>
    </div>
  </div>
</article>
