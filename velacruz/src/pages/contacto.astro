---
import Layout from '../layouts/Layout.astro';
import { ContactMap } from '../components/ContactMap';
---

<Layout title="Contacto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Contacta con <span class="text-brand">Nosotros</span></h1>
      <p class="text-xl text-zinc-400 max-w-2xl mx-auto">Estamos aquí para resolver tus dudas. Visítanos en nuestras instalaciones o escríbenos directamente.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16">
      
      <!-- Información de Contacto -->
      <div class="bg-zinc-900/40 border border-zinc-800 p-8 rounded-3xl h-full">
        <h2 class="text-2xl font-bold mb-8">Información de la exposición</h2>
        
        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Dirección</h3>
              <p class="text-zinc-400">Cuesta de Valderremata, 10 (Nave 21)</p>
              <p class="text-zinc-400">28343 Valdemoro, Madrid</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Teléfono</h3>
              <p class="text-zinc-400">644 898 574</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-brand/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Horario</h3>
              <p class="text-zinc-400">Lunes a Viernes: 10:00 - 14:00 / 16:30 - 20:00</p>
              <p class="text-zinc-400">Sábados: 10:00 - 14:00</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Formulario -->
      <div class="bg-zinc-900/40 border border-zinc-800 p-8 rounded-3xl">
        <h2 class="text-2xl font-bold mb-8">Envíanos un mensaje</h2>
        <form class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Nombre</label>
            <input type="text" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Tu nombre" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Email</label>
            <input type="email" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="tu@email.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Mensaje</label>
            <textarea rows="4" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="¿En qué podemos ayudarte?"></textarea>
          </div>
          <button type="button" class="w-full bg-brand text-zinc-950 font-bold text-lg py-4 rounded-xl hover:scale-[1.02] shadow-[0_0_15px_rgba(34,197,94,0.3)] hover:shadow-[0_0_25px_rgba(34,197,94,0.5)] transition-all duration-300">
            Enviar Mensaje
          </button>
        </form>
      </div>

    </div>

    <!-- Mapa Interactivo -->
    <div class="w-full mt-16 bg-zinc-900/40 p-4 border border-zinc-800 rounded-[2.5rem]">
      <ContactMap client:only="react" />
    </div>
  </div>
</Layout>
