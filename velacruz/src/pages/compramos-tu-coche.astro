---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Compramos tu Coche">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Máxima <span class="text-brand">Tasación</span></h1>
      <p class="text-xl text-zinc-400">Vende tu coche de forma rápida, segura y con pago inmediato. Rellena el formulario y obtén una valoración gratuita sin compromiso.</p>
    </div>

    <div class="bg-zinc-900/40 border border-zinc-800 rounded-3xl p-8 md:p-12 shadow-2xl backdrop-blur-sm">
      <form class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Marca</label>
            <input type="text" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Ej. Audi" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Modelo</label>
            <input type="text" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Ej. A6 Avant" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Año</label>
            <input type="number" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Ej. 2018" />
          </div>
          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Kilómetros</label>
            <input type="number" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Ej. 120000" />
          </div>
        </div>

        <div class="border-t border-zinc-800 pt-8 mt-8">
          <h3 class="text-xl font-semibold mb-6">Tus datos de contacto</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <label class="block text-sm font-medium text-zinc-400 mb-2">Nombre completo</label>
              <input type="text" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-400 mb-2">Teléfono</label>
              <input type="tel" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors" placeholder="Tu teléfono" />
            </div>
          </div>
        </div>

        <button type="button" class="w-full bg-brand text-zinc-950 font-bold text-lg py-4 rounded-xl mt-8 hover:scale-[1.02] shadow-[0_0_20px_rgba(34,197,94,0.3)] hover:shadow-[0_0_30px_rgba(34,197,94,0.5)] transition-all duration-300">
          Solicitar Tasación Gratuita
        </button>
      </form>
    </div>
  </div>
</Layout>
