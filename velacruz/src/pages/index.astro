---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CarCard from '../components/CarCard.astro';
import { Testimonials } from '../components/Testimonials';
import { EmissionsCarousel } from '../components/ui/emissions-carousel';
import { cars } from '../data/cars.js';

const featuredCars = cars.slice(0, 3);
---

<Layout title="Inicio">
  <Hero />
  
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12">
      <div>
        <h2 class="text-3xl md:text-5xl font-bold mb-4">Vehículos <span class="text-brand">Destacados</span></h2>
        <p class="text-zinc-400 text-lg">Nuestra selección premium de la semana, revisada y garantizada.</p>
      </div>
      <a href="/vehiculos-ocasion" class="hidden md:inline-flex items-center gap-2 text-brand hover:text-white transition-colors duration-300 font-medium">
        Ver catálogo completo
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredCars.map(car => (
        <CarCard car={car} />
      ))}
    </div>
    
    <div class="mt-12 text-center md:hidden">
      <a href="/vehiculos-ocasion" class="inline-flex items-center gap-2 text-brand hover:text-white transition-colors duration-300 font-medium">
        Ver catálogo completo
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
  
  <EmissionsCarousel cars={cars} client:load />

  <Testimonials client:load />
  
  <section class="border-t border-zinc-800 bg-transparent py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Por qué elegir <span class="text-brand">Velacruz</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="bg-zinc-900/50 p-8 rounded-3xl border border-zinc-800 hover:border-brand/50 transition-colors">
          <div class="w-14 h-14 bg-brand/10 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Revisión Exhaustiva</h3>
          <p class="text-zinc-400">Revisamos cada vehículo minuciosamente antes de su venta para garantizar su perfecto estado.</p>
        </div>
        <div class="bg-zinc-900/50 p-8 rounded-3xl border border-zinc-800 hover:border-brand/50 transition-colors">
          <div class="w-14 h-14 bg-brand/10 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Financiación Personalizada</h3>
          <p class="text-zinc-400">Adaptamos la financiación a tus necesidades para que te lleves el coche que deseas sin preocupaciones.</p>
        </div>
        <div class="bg-zinc-900/50 p-8 rounded-3xl border border-zinc-800 hover:border-brand/50 transition-colors">
          <div class="w-14 h-14 bg-brand/10 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Entrega a Domicilio</h3>
          <p class="text-zinc-400">Entregamos tu nuevo vehículo directamente en la puerta de tu casa en cualquier punto de la península.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
