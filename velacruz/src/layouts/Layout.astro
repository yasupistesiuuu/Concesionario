---
import '../styles/global.css';
import { SimpleHeader } from '../components/ui/simple-header';
import { Footer } from '../components/ui/footer-section';
import { SparkEffect } from '../components/ui/spark-effect';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Autos Velacruz - Concesionario de confianza en Valdemoro. Compra y venta de vehículos de ocasión." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Autos Velacruz</title>
	</head>
	<body class="bg-transparent text-zinc-100 flex flex-col min-h-screen relative text-base">
	  <div class="fixed inset-0 w-full h-full z-0 overflow-hidden pointer-events-none">
		  <SparkEffect client:only="react" color="34, 197, 94" maxopacity={0.6} amount={2500} />
	  </div>
		<SimpleHeader client:load />
		<main class="flex-grow pt-0 relative z-10 bg-transparent flex flex-col">
			<slot />
		</main>
		<Footer client:load />
	</body>
</html>
