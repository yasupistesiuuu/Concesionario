---
import Layout from '@/layouts/Layout.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import Navigation from '@/components/Navigation.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import HoverButton from '@/components/HoverButton.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import catalog from '@/data/catalog.json';

const title = 'Vehículos por Encargo | AUTOS VELACRUZ';
const description = 'Encuentra el vehículo perfecto. Asesoramiento personalizado, vehículos nacionales e importación, entrega a domicilio.';
const company = catalog.company;

const faqs = [
  {
    question: '¿Entrega a domicilio?',
    answer: 'Nuestro compromiso con la excelencia llega hasta la puerta de su hogar. Ofrecemos la entrega a domicilio sin trámites ni esperas innecesarias.'
  },
  {
    question: '¿Qué tipo de vehículos ofrecen por encargo?',
    answer: 'Contamos con una amplia experiencia en la localización del mejor vehículo para usted, ofreciéndole la opción de vehículos de alta gama como cualquier otro segmento del mercado.'
  },
  {
    question: '¿Asesoramiento personalizado?',
    answer: 'Le ofrecemos un asesoramiento personalizado en la elección del coche adecuado para cada cliente, aportando así nuestra experiencia para su mejor elección.'
  },
  {
    question: '¿Nacionales o importación?',
    answer: 'La mayoría de los vehículos por encargo son nacionales, pudiendo importar vehículos si usted así lo desea.'
  }
];

const features = [
  { title: 'Amplia Selección', description: 'Acceso a vehículos de todas las marcas y segmentos', icon: '🔍' },
  { title: 'Asesoramiento Experto', description: 'Equipo de profesionales con amplia experiencia', icon: '👨‍💼' },
  { title: 'Flexibilidad', description: 'Vehículos nacionales e importados según tus necesidades', icon: '🌍' },
  { title: 'Entrega Rápida', description: 'Proceso ágil desde la solicitud hasta la entrega', icon: '🚚' }
];
---

<Layout title={title} description={description}>
  <Navigation />

  <!-- HERO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 text-yellow-400">
          Vehículos por Encargo
        </h1>
        <p class="text-xl text-slate-300 mb-8">
          ¿No encuentras el vehículo que buscas? Contáctanos para encontrar el coche perfecto para ti.
        </p>
        <HoverButton href="/contacto" containerClass="h-auto inline-flex">
          Solicitar Vehículo
        </HoverButton>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold mb-16 text-yellow-400">¿Por Qué Elegirnos?</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {features.map((feature) => (
          <div class="card p-8 text-center">
            <div class="text-5xl mb-4">{feature.icon}</div>
            <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
            <p class="text-slate-400">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQS -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-4xl font-bold text-center mb-16 text-yellow-400">Preguntas Frecuentes</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="card p-8">
            <h3 class="text-2xl font-bold mb-4 text-yellow-400">{faq.question}</h3>
            <p class="text-slate-300 text-lg leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-4xl font-bold text-center mb-16 text-yellow-400">Nuestro Proceso</h2>
      <div class="space-y-8">
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">1</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Cuéntanos Qué Buscas</h3>
            <p class="text-slate-400">Describe el vehículo ideal: marca, modelo, características, presupuesto</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">2</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Búsqueda Personalizada</h3>
            <p class="text-slate-400">Nuestro equipo busca en toda España y el extranjero</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">3</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Revisión y Comprobación</h3>
            <p class="text-slate-400">Verificamos el estado mecánico y documentación completa</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">4</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Entrega a Domicilio</h3>
            <p class="text-slate-400">Te lo llevamos a casa sin trámites ni complicaciones</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE STATS -->
  <section class="section">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div class="card p-8">
          <p class="text-5xl font-bold text-yellow-400 mb-2">+20</p>
          <p class="text-xl text-slate-300">Años de Experiencia</p>
        </div>
        <div class="card p-8">
          <p class="text-5xl font-bold text-yellow-400 mb-2">1000+</p>
          <p class="text-xl text-slate-300">Clientes Satisfechos</p>
        </div>
        <div class="card p-8">
          <p class="text-5xl font-bold text-yellow-400 mb-2">⭐️ 5.0</p>
          <p class="text-xl text-slate-300">Valoración en Google</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-gradient-to-r from-yellow-500 to-yellow-600 text-slate-950">
    <div class="container text-center">
      <h2 class="text-4xl font-bold mb-6">¿Necesitas un Vehículo Específico?</h2>
      <p class="text-xl mb-8 opacity-90">Contáctanos y encontraremos el coche perfecto para ti</p>
      <a href="/contacto" class="inline-block px-12 py-4  text-yellow-400 font-bold rounded-lg hover:bg-opacity-80 transition-all">
        Solicitar Vehículo por Encargo
      </a>
    </div>
  </section>

  <!-- FOOTER ANIMATED -->
  <FooterAnimated />
</Layout>
