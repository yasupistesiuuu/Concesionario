---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import catalog from '@/data/catalog.json';

export async function getStaticPaths() {
  return [
    { params: { emission: 'C' } },
    { params: { emission: 'B' } },
    { params: { emission: 'ECO' } },
    { params: { emission: 'CERO' } }
  ];
}

const { emission } = Astro.params;
const company = catalog.company;

// Filtrar vehículos por etiqueta
const vehicles = catalog.vehicles.filter(v => v.emission === emission);

const emissionInfo = {
  'C': {
    label: 'Etiqueta C',
    color: 'bg-yellow-600',
    description: 'Vehículos con emisiones moderadas',
    badge: 'C'
  },
  'B': {
    label: 'Etiqueta B',
    color: 'bg-green-700',
    description: 'Vehículos con bajas emisiones',
    badge: 'B'
  },
  'ECO': {
    label: 'Etiqueta ECO',
    color: 'bg-green-500',
    description: 'Vehículos ecológicos (híbridos)',
    badge: 'ECO'
  },
  'CERO': {
    label: 'Etiqueta CERO',
    color: 'bg-blue-600',
    description: 'Vehículos de cero emisiones (eléctricos)',
    badge: '0'
  }
};

const info = emissionInfo[emission];
const title = `${info.label} | AUTOS VELACRUZ`;
const description = `${vehicles.length} vehículos con ${info.label.toLowerCase()}. ${info.description}`;

const getEmissionColor = (emission) => {
  const colors = {
    'C': 'bg-yellow-600',
    'B': 'bg-green-700',
    'ECO': 'bg-green-500',
    'CERO': 'bg-blue-600'
  };
  return colors[emission] || 'bg-slate-600';
};
---

<Layout title={title} description={description}>
  <Navigation />

  <!-- HERO -->
  <section class="section bg-gradient-to-b from-slate-900 to-slate-950">
    <div class="container">
      <div class="flex items-center gap-6 mb-6">
        <div class={`${info.color} inline-block px-6 py-3 rounded-full text-white font-bold text-4xl`}>
          {info.badge}
        </div>
        <div>
          <h1 class="text-5xl md:text-6xl font-bold text-yellow-400">
            {info.label}
          </h1>
          <p class="text-xl text-slate-300 mt-2">{info.description}</p>
        </div>
      </div>
      <p class="text-2xl text-slate-400 font-semibold">{vehicles.length} vehículos disponibles</p>
    </div>
  </section>

  <!-- VEHICLES GRID -->
  <section class="section bg-slate-950">
    <div class="container">
      {vehicles.length > 0 ? (
        <div class="grid md:grid-cols-3 gap-8">
          {vehicles.map((vehicle) => (
            <div class="card overflow-hidden relative hover:shadow-2xl transition-all duration-300">
              <img src={vehicle.image} alt={vehicle.name} class="w-full h-48 object-cover rounded-t-lg aspect-video" />
              <div class={`absolute top-3 right-3 ${getEmissionColor(vehicle.emission)} px-3 py-1 rounded-full text-white font-bold text-sm`}>
                {vehicle.emission}
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg mb-2 text-white">{vehicle.name}</h3>
                <p class="text-3xl font-bold text-yellow-400 mb-4">{vehicle.price}€</p>
                <ul class="text-sm text-slate-400 space-y-2 mb-6 pb-6 border-b border-slate-700">
                  <li class="flex justify-between">
                    <span>Año:</span>
                    <span class="font-semibold">{vehicle.year}</span>
                  </li>
                  <li class="flex justify-between">
                    <span>Kilómetros:</span>
                    <span class="font-semibold">{vehicle.km}</span>
                  </li>
                  <li class="flex justify-between">
                    <span>Combustible:</span>
                    <span class="font-semibold">{vehicle.fuel}</span>
                  </li>
                  <li class="flex justify-between">
                    <span>Transmisión:</span>
                    <span class="font-semibold">{vehicle.transmission}</span>
                  </li>
                </ul>
                <div class="space-y-2">
                  <button class="btn-primary block w-full py-2 text-center">
                    Solicitar Información
                  </button>
                  <a href="/contacto" class="btn-secondary block w-full py-2 text-center">
                    Agendar Test Drive
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-2xl text-slate-400 mb-8">No hay vehículos disponibles con esta etiqueta en este momento.</p>
          <a href="/catalogo" class="btn-primary inline-block">
            Ver Todo el Catálogo
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-gradient-to-r from-yellow-500 to-yellow-600 text-slate-950">
    <div class="container text-center">
      <h2 class="text-4xl font-bold mb-6">¿No encuentras lo que buscas?</h2>
      <p class="text-xl mb-8 opacity-90">Solicita un vehículo por encargo con la etiqueta ambiental que prefieres</p>
      <a href="/vehiculos-por-encargo" class="inline-block px-12 py-4 bg-slate-950 text-yellow-400 font-bold rounded-lg hover:bg-opacity-80 transition-all">
        Solicitar Vehículo por Encargo
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-slate-900 border-t border-yellow-500/30 py-12">
    <div class="container">
      <div class="grid md:grid-cols-4 gap-8 mb-8">
        <div>
          <h4 class="font-bold text-yellow-400 mb-4">{company.name}</h4>
          <p class="text-slate-400 text-sm">{company.location}</p>
        </div>
        <div>
          <h4 class="font-bold mb-4">Navegación</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="text-slate-400 hover:text-yellow-400">Inicio</a></li>
            <li><a href="/catalogo" class="text-slate-400 hover:text-yellow-400">Catálogo</a></li>
            <li><a href="/contacto" class="text-slate-400 hover:text-yellow-400">Contacto</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4">Empresa</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/compramos-tu-coche" class="text-slate-400 hover:text-yellow-400">Compramos Tu Coche</a></li>
            <li><a href="/vehiculos-por-encargo" class="text-slate-400 hover:text-yellow-400">Vehículos por Encargo</a></li>
            <li><a href="/sobre-nosotros" class="text-slate-400 hover:text-yellow-400">Sobre Nosotros</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4">Contacto</h4>
          <p class="text-slate-400 text-sm">📍 {company.location}</p>
          <p class="text-slate-400 text-sm">📧 {company.email}</p>
          <p class="text-slate-400 text-sm">📞 {company.phone}</p>
        </div>
      </div>
      <div class="border-t border-yellow-500/30 pt-8 text-center text-slate-400 text-sm">
        <p>&copy; 2026 {company.name}. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>
</Layout>
