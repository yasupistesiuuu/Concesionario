---
import Layout from '@/layouts/Layout.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import Navigation from '@/components/Navigation.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import catalog from '@/data/catalog.json';

const title = 'Contacto | AUTOS VELACRUZ';
const description = 'Contacta con AUTOS VELACRUZ para consultas, tasación o reservar un test drive.';
const company = catalog.company;
---

<Layout title={title} description={description}>
  <Navigation />

  <!-- HERO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 text-yellow-400">
          Contacta Con Nosotros
        </h1>
        <p class="text-xl text-slate-300">
          Estamos aquí para ayudarte. Contáctanos por teléfono, email o visítanos en persona.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT INFO & FORM -->
  <section class="section">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-12 mb-12">
        <div>
          <h2 class="text-4xl font-bold mb-8 text-yellow-400">Información de Contacto</h2>

          <div class="mb-8">
            <h3 class="text-2xl font-bold mb-3">Dirección</h3>
            <p class="text-slate-300 text-lg">Cuesta de Valderremata, 10 (Nave 21)</p>
            <p class="text-slate-300 text-lg">28343 Valdemoro, Madrid</p>
          </div>

          <div class="mb-8">
            <h3 class="text-2xl font-bold mb-3">Teléfono</h3>
            <a href="tel:+34916330044" class="text-yellow-400 text-lg font-semibold hover:text-yellow-300">
              +34 916 33 00 44
            </a>
          </div>

          <div class="mb-8">
            <h3 class="text-2xl font-bold mb-3">Email</h3>
            <a href="mailto:autosvelacruz@gmail.com" class="text-yellow-400 text-lg font-semibold hover:text-yellow-300">
              autosvelacruz@gmail.com
            </a>
          </div>

          <div class="mb-8">
            <h3 class="text-2xl font-bold mb-4">Síguenos</h3>
            <div class="flex gap-4">
              <a href="https://www.facebook.com/autosvelacruz" target="_blank" class="text-slate-400 hover:text-yellow-400 transition-colors text-2xl">
                f
              </a>
              <a href="https://www.instagram.com/autosvelacruz/" target="_blank" class="text-slate-400 hover:text-yellow-400 transition-colors text-2xl">
                📷
              </a>
              <a href="https://www.tiktok.com/@autosvelacruz" target="_blank" class="text-slate-400 hover:text-yellow-400 transition-colors text-2xl">
                🎵
              </a>
            </div>
          </div>

          <div class="card p-6  border-l-4 border-yellow-500">
            <p class="text-slate-300 font-semibold mb-2">Horario de Atención</p>
            <p class="text-slate-400">Lunes a Viernes: 9:00 - 19:00</p>
            <p class="text-slate-400">Sábados: 10:00 - 14:00</p>
            <p class="text-slate-400">Domingos: Cerrado</p>
          </div>
        </div>

        <div>
          <h2 class="text-4xl font-bold mb-8 text-yellow-400">Envíanos un Mensaje</h2>
          <form class="space-y-6">
            <div>
              <input
                type="text"
                placeholder="Tu nombre completo"
                class="w-full  border border-slate-700 rounded px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-yellow-400 focus:outline-none transition-colors"
                required
              />
            </div>
            <div>
              <input
                type="email"
                placeholder="Tu email"
                class="w-full  border border-slate-700 rounded px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-yellow-400 focus:outline-none transition-colors"
                required
              />
            </div>
            <div>
              <input
                type="tel"
                placeholder="Tu teléfono (opcional)"
                class="w-full  border border-slate-700 rounded px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-yellow-400 focus:outline-none transition-colors"
              />
            </div>
            <div>
              <select class="w-full  border border-slate-700 rounded px-4 py-3 text-slate-100 focus:border-yellow-400 focus:outline-none transition-colors">
                <option value="">Selecciona el motivo de tu consulta</option>
                <option value="test-drive">Agendar Test Drive</option>
                <option value="informacion">Solicitar Información</option>
                <option value="tasacion">Tasación de Vehículo</option>
                <option value="encargo">Vehículo por Encargo</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <textarea
                placeholder="Tu mensaje"
                rows="5"
                class="w-full  border border-slate-700 rounded px-4 py-3 text-slate-100 placeholder:text-slate-500 focus:border-yellow-400 focus:outline-none transition-colors resize-none"
              ></textarea>
            </div>
            <button type="submit" class="btn-primary w-full py-3">
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP / LOCATION -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold text-center mb-12 text-yellow-400">Nuestra Ubicación</h2>
      <div class=" rounded-lg overflow-hidden h-96">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3049.2285474628397!2d-3.6439340!3d40.3030060!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd418f5e5f5f5f5f%3A0x0!2sAutos%20Velacruz!5e0!3m2!1ses!2ses!4v1681234567890"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container text-center">
      <h2 class="text-4xl font-bold mb-6 text-yellow-400">¿Tienes Alguna Pregunta?</h2>
      <p class="text-xl mb-8 text-slate-300">Nuestro equipo está listo para ayudarte</p>
      <a href="tel:+34916330044" class="inline-block px-12 py-4 text-yellow-400 font-bold rounded-lg hover:text-yellow-300 transition-all">
        Llamar Ahora
      </a>
    </div>
  </section>

  <!-- FOOTER ANIMATED -->
  <FooterAnimated />
</Layout>
