---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';

const title = 'Contacto | AUTOS VELACRUZ';
const description = 'Contacta con nosotros para reservar tu test drive';
---

<Layout title={title} description={description}>
  <Navigation />
  <section class="section bg-luxury-dark">
    <div class="container max-w-2xl">
      <h1 class="text-5xl font-bold mb-16">Contacto</h1>
      <div class="grid md:grid-cols-2 gap-12 mb-12">
        <div>
          <h3 class="text-2xl font-bold mb-4">Información de Contacto</h3>
          <p class="mb-4">📍 Valdemoro, Madrid</p>
          <p class="mb-4">📧 contacto@autosvelacruz.es</p>
          <p class="mb-4">📞 +34 XXX XXX XXX</p>
        </div>
        <form class="space-y-4">
          <input type="text" placeholder="Tu nombre" class="w-full bg-luxury-accent border border-luxury-gold/30 rounded px-4 py-2 text-luxury-silver" />
          <input type="email" placeholder="Tu email" class="w-full bg-luxury-accent border border-luxury-gold/30 rounded px-4 py-2 text-luxury-silver" />
          <textarea placeholder="Tu mensaje" rows="4" class="w-full bg-luxury-accent border border-luxury-gold/30 rounded px-4 py-2 text-luxury-silver"></textarea>
          <button type="submit" class="btn-primary w-full">Enviar</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
