---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import HoverButton from '@/components/HoverButton.astro';
import catalog from '@/data/catalog.json';

const title = 'Catálogo Completo | AUTOS VELACRUZ';
const description = '61 vehículos de lujo disponibles. Desde 4.500€. Financiación, entrega a domicilio, vehículos revisados.';
const vehicles = catalog.vehicles;

const getEmissionColor = (emission) => {
  const colors = {
    'C': 'bg-yellow-600',
    'B': 'bg-green-700',
    'ECO': 'bg-green-500',
    'CERO': 'bg-blue-600'
  };
  return colors[emission] || 'bg-slate-600';
};
---

<Layout title={title} description={description}>
  <Navigation />

  <section class="section bg-slate-950">
    <div class="container">
      <h1 class="text-5xl font-bold mb-4 text-yellow-400">Nuestro Catálogo Completo</h1>
      <p class="text-xl text-slate-400 mb-12">Total: {vehicles.length} vehículos disponibles</p>

      <div class="grid md:grid-cols-3 gap-8">
        {vehicles.map((vehicle) => (
          <div class="card overflow-hidden relative hover:shadow-2xl transition-shadow duration-300" id={vehicle.slug}>
            <img src={vehicle.image} alt={vehicle.name} class="w-full h-48 object-cover rounded-t-lg aspect-video" />
            <div class={`absolute top-3 right-3 ${getEmissionColor(vehicle.emission)} px-3 py-1 rounded-full text-white font-bold text-sm`}>
              {vehicle.emission}
            </div>
            <div class="p-6">
              <h3 class="font-bold text-lg mb-2 text-white">{vehicle.name}</h3>
              <div class="mb-4">
                <p class="text-3xl font-bold text-yellow-400">{vehicle.price}€</p>
                <p class="text-sm text-slate-400">Financiado desde 200€/mes</p>
              </div>
              <ul class="text-sm text-slate-400 space-y-2 mb-6 pb-6 border-b border-slate-700">
                <li class="flex justify-between">
                  <span>Año:</span>
                  <span class="font-semibold">{vehicle.year}</span>
                </li>
                <li class="flex justify-between">
                  <span>Kilómetros:</span>
                  <span class="font-semibold">{vehicle.km}</span>
                </li>
                <li class="flex justify-between">
                  <span>Combustible:</span>
                  <span class="font-semibold">{vehicle.fuel}</span>
                </li>
                <li class="flex justify-between">
                  <span>Transmisión:</span>
                  <span class="font-semibold">{vehicle.transmission}</span>
                </li>
              </ul>
              <div class="space-y-2">
                <HoverButton containerClass="w-full" className="w-full py-2 text-center">
                  Solicitar Información
                </HoverButton>
                <HoverButton href="/contacto" containerClass="w-full" className="w-full py-2 text-center">
                  Agendar Test Drive
                </HoverButton>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <p class="text-lg text-slate-400 mb-8">
          ¿No encuentra lo que busca? Contáctenos para vehículos por encargo o consultar opciones especiales.
        </p>
        <HoverButton href="/contacto" containerClass="h-auto inline-flex">
          Contactar Asesor Especializado
        </HoverButton>
      </div>
    </div>
  </section>
</Layout>
