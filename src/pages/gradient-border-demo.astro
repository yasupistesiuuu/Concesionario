---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import BorderRotateDemo from '@/components/BorderRotateDemo.tsx';
---

<Layout title="Animated Gradient Border Demo | AUTOS VELACRUZ">
  <Navigation />

  <section class="section py-20">
    <div class="container">
      <h1 class="text-5xl font-bold text-center mb-4 text-black">
        Animated Gradient Border Component
      </h1>
      <p class="text-xl text-center text-slate-400 mb-16">
        Premium animated border component with customizable gradients and animations
      </p>

      <BorderRotateDemo client:load />
    </div>
  </section>
</Layout>
