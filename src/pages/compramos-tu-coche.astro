---
import Layout from '@/layouts/Layout.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import Navigation from '@/components/Navigation.astro';
import HoverButton from '@/components/HoverButton.astro';
import { FAQAccordion } from '@/components/blocks/FAQAccordion';
import catalog from '@/data/catalog.json';

const title = 'Compramos Tu Coche | AUTOS VELACRUZ';
const description = 'Tasación gratuita, máxima tasación, pago inmediato y cambio de titularidad. Vende tu coche en Valdemoro.';
const company = catalog.company;

const benefits = [
  { title: 'Máxima Tasación', description: 'Ofrecemos el mejor precio por tu vehículo', icon: '💰' },
  { title: 'Cambio de Titularidad', description: 'Nos encargamos de toda la documentación', icon: '📋' },
  { title: 'Pago Inmediato', description: 'Recibe el dinero el mismo día', icon: '⚡' },
  { title: 'Tasación Gratuita', description: 'Sin compromiso, sin costos', icon: '✅' },
  { title: 'Proceso Fácil y Rápido', description: 'Trámites sencillos sin esperas', icon: '🚀' }
];

const testimonials = [
  {
    text: 'Quisiera agradecerles la experiencia tan satisfactoria de haberles comprado un coche. El coche está en unas condiciones excelentes, el trato por parte de David y Raúl es más que destacable.',
    author: 'Rodrigo Bernasconi',
    role: 'Cliente'
  },
  {
    text: 'Simplemente encantado!!! Todo súper ágil y súper fácil con David, el cual el trato ha sido inmejorable. Los mejores precios y estados de coches.',
    author: 'Julián Arenas Carrillo',
    role: 'Cliente'
  },
  {
    text: 'Hace ya más de un año que compré mi coche y estoy encantada, está igual de bien que el primer día. Destacaría especialmente la transparencia en cuanto a las gestiones.',
    author: 'Merce P. D.',
    role: 'Cliente'
  },
  {
    text: 'Unos profesionales increíbles!!! David lleva el mundo del motor en la sangre, le gustan los coches, ama los coches.',
    author: 'Álvaro Merino',
    role: 'Cliente'
  }
];

const faqs = [
  {
    question: '¿Cuánto vale mi coche?',
    answer: 'Realizamos una tasación gratuita y sin compromiso. Evaluamos el estado mecánico, estético, historial de mantenimiento y documentación. Ofrecemos siempre la mejor oferta del mercado.'
  },
  {
    question: '¿Cuánto tiempo tarda el proceso?',
    answer: 'El proceso es rápido: tasación gratuita (15-30 min), propuesta económica inmediata, y pago en el acto. Todo puede completarse en una sola visita.'
  },
  {
    question: '¿Qué pasa con la documentación?',
    answer: 'Nos encargamos de toda la documentación incluido el cambio de titularidad. No tienes que preocuparte de nada, solo del trámite administrativo mínimo.'
  },
  {
    question: '¿Compran coches con problemas mecánicos?',
    answer: 'Sí, compramos vehículos en cualquier estado: accidentados, con averías, altas millas o antigüedad. Realizamos una evaluación justa según su condición.'
  },
  {
    question: '¿Es obligatorio aceptar la oferta?',
    answer: 'No, la tasación es completamente sin compromiso. Te ofrecemos la mejor oferta, pero tú decides si aceptarla o no.'
  }
];
---

<Layout title={title} description={description}>
  <Navigation />

  <!-- HERO -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 text-yellow-400">
          Compramos Tu Coche
        </h1>
        <p class="text-xl text-slate-300 mb-8">
          Vende tu vehículo al mejor precio con nosotros. Tasación gratuita, pago inmediato y sin complicaciones.
        </p>
        <HoverButton href="/contacto" containerClass="h-auto inline-flex">
          Solicitar Tasación
        </HoverButton>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold mb-16 text-yellow-400">Nuestro Proceso</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {benefits.map((benefit) => (
          <div class="card p-8 text-center">
            <div class="text-5xl mb-4">{benefit.icon}</div>
            <h3 class="text-2xl font-bold mb-3">{benefit.title}</h3>
            <p class="text-slate-400">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold text-center mb-16 text-yellow-400">Lo Que Dicen Nuestros Clientes</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {testimonials.map((test) => (
          <div class="card p-8 border-l-4 border-yellow-500">
            <p class="text-lg italic text-slate-300 mb-6">"{test.text}"</p>
            <div>
              <p class="font-bold text-yellow-400">{test.author}</p>
              <p class="text-slate-400 text-sm">{test.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQS ACCORDION -->
  <FAQAccordion client:load faqs={faqs} title="Preguntas Frecuentes" subtitle="Resolvemos tus dudas sobre vender tu coche" />

  <!-- HOW IT WORKS -->
  <section class="section">
    <div class="container max-w-3xl">
      <h2 class="text-4xl font-bold text-center mb-16 text-yellow-400">¿Cómo Funciona?</h2>
      <div class="space-y-8">
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">1</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Contacta con Nosotros</h3>
            <p class="text-slate-400">Llama, escribe o visítanos para conocer tu vehículo</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">2</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Tasación Gratuita</h3>
            <p class="text-slate-400">Evaluamos tu coche sin compromiso y ofrecemos el mejor precio</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">3</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Pago Inmediato</h3>
            <p class="text-slate-400">Si aceptas la propuesta, recibe el dinero en el acto</p>
          </div>
        </div>
        <div class="flex gap-6">
          <div class="text-4xl font-bold text-yellow-400 flex-shrink-0">4</div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Cambio de Titularidad</h3>
            <p class="text-slate-400">Nos encargamos de toda la documentación</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container text-center">
      <h2 class="text-4xl font-bold mb-6 text-yellow-400">¿Listo para Vender Tu Coche?</h2>
      <p class="text-xl mb-8 text-slate-300">Contáctanos para una tasación sin compromiso</p>
      <a href="/contacto" class="inline-block px-12 py-4 text-yellow-400 font-bold rounded-lg hover:text-yellow-300 transition-all">
        Solicitar Tasación Ahora
      </a>
    </div>
  </section>

  <!-- FOOTER ANIMATED -->
  <FooterAnimated />
</Layout>
