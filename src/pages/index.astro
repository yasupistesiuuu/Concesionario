---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import HoverButton from '@/components/HoverButton.astro';
import HeroAnimated from '@/components/HeroAnimated.astro';
import GradientCard from '@/components/GradientCard.astro';
import FooterAnimated from '@/components/FooterAnimated.astro';
import catalog from '@/data/catalog.json';

const title = 'AUTOS VELACRUZ | Concesionario de Lujo en Valdemoro';
const description = 'Amplia selección de vehículos de segunda mano y ocasión. Financiación personalizada, entrega a domicilio, máxima tasación.';
const featured = catalog.vehicles.slice(0, 6);
const testimonials = catalog.testimonials;
const company = catalog.company;

const getEmissionColor = (emission) => {
  const colors = {
    'C': 'bg-yellow-600',
    'B': 'bg-green-700',
    'ECO': 'bg-green-500',
    'CERO': 'bg-blue-600'
  };
  return colors[emission] || 'bg-slate-600';
};

// Agrupar vehículos por etiqueta
const emissionTags = {
  'C': {
    label: 'C',
    color: 'bg-yellow-600',
    count: catalog.vehicles.filter(v => v.emission === 'C').length
  },
  'B': {
    label: 'B',
    color: 'bg-green-700',
    count: catalog.vehicles.filter(v => v.emission === 'B').length
  },
  'ECO': {
    label: 'ECO',
    color: 'bg-green-500',
    count: catalog.vehicles.filter(v => v.emission === 'ECO').length
  },
  'CERO': {
    label: '0',
    color: 'bg-blue-600',
    count: catalog.vehicles.filter(v => v.emission === 'CERO').length
  }
};
---

<Layout title={title} description={description}>
  <Navigation />

  <!-- HERO ANIMATED -->
  <HeroAnimated
    title={company.tagline}
    description={company.description}
    primaryButtonText="Ver Catálogo Completo"
    primaryButtonHref="/catalogo"
    secondaryButtonText="Contactar Ahora"
    secondaryButtonHref="/contacto"
    image="/cocheHero.jpg"
    imageAlt="Vehículos de Lujo"
  />

  <!-- FEATURES -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold text-center mb-16 text-yellow-400">¿Por Qué Elegirnos?</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {company.features.map((feature) => (
          <GradientCard animationMode="auto-rotate" animationSpeed={4}>
            <div class="p-6">
              <div class="text-5xl mb-4">{feature.icon === 'grid' ? '🏆' : feature.icon === 'truck' ? '🚚' : feature.icon === 'check' ? '✅' : '💰'}</div>
              <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
              <p class="text-slate-400">{feature.description}</p>
            </div>
          </GradientCard>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED VEHICLES -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold mb-16 text-yellow-400">Vehículos Destacados</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {featured.map((vehicle) => (
          <GradientCard animationMode="rotate-on-hover" animationSpeed={3}>
            <div class="overflow-hidden relative">
              <img src={vehicle.image} alt={vehicle.name} class="w-full h-48 object-cover" />
              <div class={`absolute top-3 right-3 ${getEmissionColor(vehicle.emission)} px-3 py-1 rounded-full text-white font-bold text-sm`}>
                {vehicle.emission}
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg mb-2 text-white">{vehicle.name}</h3>
                <p class="text-yellow-400 text-2xl font-bold mb-4">{vehicle.price}€</p>
                <ul class="text-sm text-slate-400 space-y-1 mb-4">
                  <li>📅 {vehicle.year} | {vehicle.km} km</li>
                  <li>⛽ {vehicle.fuel} | ⚙️ {vehicle.transmission}</li>
                </ul>
                <HoverButton href={`/catalogo#${vehicle.slug}`} containerClass="w-full" className="w-full text-center py-2 text-sm">
                  Ver Detalles
                </HoverButton>
              </div>
            </div>
          </GradientCard>
        ))}
      </div>
      <div class="text-center mt-12">
        <HoverButton href="/catalogo" containerClass="h-auto">
          Ver Todo el Inventario
        </HoverButton>
      </div>
    </div>
  </section>

  <!-- DISTINTIVO AMBIENTAL -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold mb-16 text-yellow-400">Distintivo Ambiental</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {Object.entries(emissionTags).map(([key, tag]) => (
          <a href={`/etiqueta/${key}`} class={`card p-8 text-center border-2 border-slate-700 hover:border-yellow-400 hover:shadow-lg transition-all cursor-pointer`}>
            <div class={`${tag.color} inline-block px-6 py-3 rounded-full text-white font-bold text-3xl mb-4`}>
              {tag.label}
            </div>
            <p class="text-3xl font-bold text-yellow-400 mb-2">{tag.count}</p>
            <p class="text-slate-400">
              {key === 'C' && 'Emisiones Moderadas'}
              {key === 'B' && 'Bajas Emisiones'}
              {key === 'ECO' && 'Ecológicos (Híbridos)'}
              {key === 'CERO' && 'Cero Emisiones (Eléctricos)'}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section">
    <div class="container">
      <h2 class="text-4xl font-bold text-center mb-16 text-yellow-400">Opiniones de Clientes</h2>
      <div class="grid md:grid-cols-2 gap-12">
        {testimonials.map((test) => (
          <GradientCard animationMode="rotate-on-hover" animationSpeed={3}>
            <div class="p-8">
              <p class="text-lg italic text-slate-300 mb-6">"{test.text}"</p>
              <div>
                <p class="font-bold text-yellow-400">{test.author}</p>
                <p class="text-slate-400 text-sm">{test.role}</p>
              </div>
            </div>
          </GradientCard>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-gradient-to-r from-yellow-500 to-yellow-600 text-slate-950">
    <div class="container text-center">
      <h2 class="text-4xl font-bold mb-6">Encuentra Tu Vehículo Ideal Hoy</h2>
      <p class="text-xl mb-8 opacity-90">Contáctanos para una consulta sin compromiso</p>
      <HoverButton href="/contacto" containerClass="h-auto inline-flex" className="px-8 py-3 text-lg  text-yellow-400">
        Reservar Cita
      </HoverButton>
    </div>
  </section>

  <!-- FOOTER ANIMATED -->
  <FooterAnimated />
</Layout>
