---
import '@/styles/global.css';
import '@/styles/hover-button.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Autos Velacruz - Concesionario de Lujo',
  description = 'Descubre nuestra exclusiva selección de vehículos de segunda mano y ocasión. Financiación a medida, entrega a domicilio y máxima tasación en tu coche.',
  canonical = 'https://autosvelacruz.es'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="concesionario, coches de ocasión, segunda mano, vehículos de lujo, Madrid, financiación" />
    <meta name="author" content="Autos Velacruz" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="text-luxury-silver font-luxury antialiased">
    <div class="min-h-screen flex flex-col relative z-10">
      <slot />
    </div>

    <style is:global>
      body {
        background: linear-gradient(-45deg, #ff6b6b, #ee5a6f, #c44569, #f8b195, #f67280, #c06c84, #6c5b7b, #355c7d);
        background-size: 300% 300%;
        background-position: 0% 50%;
        animation: gradient 15s ease infinite;
      }

      @keyframes gradient {
        0% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
        100% {
          background-position: 0% 50%;
        }
      }
    </style>
  </body>
</html>
