---
import '@/styles/global.css';
import '@/styles/hover-button.css';
import ShaderBackgroundLayer from '@/components/ShaderBackgroundLayer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Autos Velacruz - Concesionario de Lujo',
  description = 'Descubre nuestra exclusiva selección de vehículos de segunda mano y ocasión. Financiación a medida, entrega a domicilio y máxima tasación en tu coche.',
  canonical = 'https://autosvelacruz.es'
} = Astro.props;
---

<!doctype html>
<html lang="es" style="background-color: #0a0e27;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="concesionario, coches de ocasión, segunda mano, vehículos de lujo, Madrid, financiación" />
    <meta name="author" content="Autos Velacruz" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="text-luxury-silver font-luxury antialiased overflow-x-hidden" style="background: inherit;">
    <!-- Shader Background Layer (3D Animated) -->
    <ShaderBackgroundLayer />

    <!-- Fondo Vivo Animado (Grid) -->
    <div class="fixed inset-0 -z-10 h-full w-full bg-[#0a0a0a] bg-[linear-gradient(to_right,#1f1f1f_1px,transparent_1px),linear-gradient(to_bottom,#1f1f1f_1px,transparent_1px)] bg-[size:4rem_4rem]">
      <div class="absolute inset-0 bg-[radial-gradient(circle_400px_at_50%_300px,#1a1a1a,transparent)] animate-pulse-slow pointer-events-none"></div>
    </div>

    <div class="min-h-screen flex flex-col relative z-20">
      <slot />
    </div>
  </body>
</html>
