---
import '@/styles/global.css';
import '@/styles/hover-button.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Autos Velacruz - Concesionario de Lujo',
  description = 'Descubre nuestra exclusiva selección de vehículos de segunda mano y ocasión. Financiación a medida, entrega a domicilio y máxima tasación en tu coche.',
  canonical = 'https://autosvelacruz.es'
} = Astro.props;
---

<!doctype html>
<html lang="es" style="background: linear-gradient(135deg, #f8f7f5 0%, #faf9f7 50%, #f5f4f2 100%); background-attachment: fixed;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="concesionario, coches de ocasión, segunda mano, vehículos de lujo, Madrid, financiación" />
    <meta name="author" content="Autos Velacruz" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Autos Velacruz" />
    <meta property="og:image" content="https://autosvelacruz.es/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/svg+xml" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://autosvelacruz.es/og-image.svg" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD Schema.org -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Autos Velacruz",
      "image": "https://autosvelacruz.es/og-image.svg",
      "description": "Concesionario de lujo en Valdemoro. Amplia selección de vehículos de segunda mano y ocasión. Financiación personalizada, entrega a domicilio, máxima tasación.",
      "url": "https://autosvelacruz.es",
      "telephone": "+34916330044",
      "email": "autosvelacruz@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Valdemoro",
        "addressRegion": "Madrid",
        "postalCode": "28340",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "40.1895",
        "longitude": "-3.6426"
      },
      "sameAs": [
        "https://www.facebook.com/autosvelacruz",
        "https://www.instagram.com/autosvelacruz/",
        "https://www.tiktok.com/@autosvelacruz"
      ]
    }
    </script>
  </head>
  <body class="text-luxury-silver font-luxury antialiased overflow-x-hidden" style="background: inherit;">
    <!-- Fondo Blanco Humo Premium con Reflejos (Fixed Z-index) -->
    <div class="fixed inset-0 w-full h-full" style="z-index: -50; background: linear-gradient(135deg, #f8f7f5 0%, #faf9f7 50%, #f5f4f2 100%); background-attachment: fixed;">
      <!-- Reflejos sutiles -->
      <div class="absolute inset-0" style="background: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.8) 0%, transparent 50%);"></div>
      <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 80%, rgba(255, 255, 255, 0.6) 0%, transparent 50%);"></div>
      <div class="absolute inset-0" style="background: radial-gradient(circle at 40% 0%, rgba(255, 248, 240, 0.5) 0%, transparent 40%);"></div>
    </div>

    <div class="min-h-screen flex flex-col relative z-20">
      <slot />
    </div>
  </body>
</html>
