---
// Three.js Aurora Shader Background
import { initThreeShaderBackground } from '@/scripts/three-shader.js';
---

<canvas id="three-canvas"></canvas>

<script>
  import { initThreeShaderBackground } from '@/scripts/three-shader.js';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThreeShaderBackground);
  } else {
    initThreeShaderBackground();
  }
</script>

<style>
  #three-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>
