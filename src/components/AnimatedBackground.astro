---
// Canvas 2D Background
---

<canvas id="bg-canvas"></canvas>

<script>
  console.log('AnimatedBackground script starting...');

  let canvas = document.querySelector('canvas');
  if (!canvas) {
    console.error('Canvas not found!');
    // Create canvas if not found
    canvas = document.createElement('canvas');
    canvas.id = 'bg-canvas';
    canvas.style.position = 'fixed';
    canvas.style.top = '0';
    canvas.style.left = '0';
    canvas.style.zIndex = '0';
    canvas.style.pointerEvents = 'none';
    document.body.insertBefore(canvas, document.body.firstChild);
  }

  const ctx = canvas.getContext('2d');
  if (!ctx) {
    console.error('Could not get 2D context');
  } else {
    console.log('Canvas context OK');
  }

  // Set canvas size
  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    console.log(`Canvas resized to ${canvas.width}x${canvas.height}`);
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  // Animation
  let time = 0;
  function animate() {
    // Draw simple blue background
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Draw gradient
    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, `hsl(${time % 360}, 70%, 40%)`);
    gradient.addColorStop(1, `hsl(${(time + 180) % 360}, 70%, 40%)`);
    ctx.fillStyle = gradient;
    ctx.globalAlpha = 0.5;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.globalAlpha = 1;

    if (time === 0) {
      console.log('First frame drawn');
    }
    time++;
    requestAnimationFrame(animate);
  }

  animate();
</script>

<style>
  canvas#bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>
