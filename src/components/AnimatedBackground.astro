---
// Canvas 2D Background
---

<canvas id="bg-canvas"></canvas>

<script>
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // Set canvas size
  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  // Animation
  let time = 0;
  function animate() {
    // Draw gradient background
    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, `hsl(${time % 360}, 70%, 30%)`);
    gradient.addColorStop(0.5, `hsl(${(time + 60) % 360}, 70%, 20%)`);
    gradient.addColorStop(1, `hsl(${(time + 120) % 360}, 70%, 35%)`);

    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Draw animated circles
    for (let i = 0; i < 5; i++) {
      const x = canvas.width / 2 + Math.cos(time * 0.0005 + i) * 300;
      const y = canvas.height / 2 + Math.sin(time * 0.0003 + i * 0.5) * 200;
      const r = 100 + Math.sin(time * 0.001 + i) * 50;

      const circleGradient = ctx.createRadialGradient(x, y, 0, x, y, r);
      circleGradient.addColorStop(0, `hsla(${(time + i * 60) % 360}, 100%, 60%, 0.4)`);
      circleGradient.addColorStop(1, `hsla(${(time + i * 60) % 360}, 100%, 40%, 0)`);

      ctx.fillStyle = circleGradient;
      ctx.fillRect(x - r, y - r, r * 2, r * 2);
    }

    time++;
    requestAnimationFrame(animate);
  }

  animate();
</script>

<style>
  canvas#bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>
