---
import CosmicButton from '@/components/CosmicButton.astro';
import '@/styles/hero-animated.css';

interface Props {
  title: string;
  titleHighlight?: string;
  description: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  titleHighlight = '',
  description,
  primaryButtonText = 'Ver Catálogo',
  primaryButtonHref = '/catalogo',
  secondaryButtonText = 'Contactar',
  secondaryButtonHref = '/contacto',
  image = '/cocheHero.jpg',
  imageAlt = 'Destacado'
} = Astro.props;
---

<section class="hero-animated section w-full">
  <div class="w-full px-4 md:px-8 lg:px-16">
    <div class="grid md:grid-cols-2 gap-12 items-center w-full">
      <div class="hero-animated-content">
        <h1 class="hero-title">
          {title}
          {titleHighlight && <strong>{titleHighlight}</strong>}
        </h1>
        <p class="hero-description">
          {description}
        </p>
        <div class="hero-buttons">
          <CosmicButton href={primaryButtonHref}>
            {primaryButtonText}
          </CosmicButton>
          <CosmicButton href={secondaryButtonHref}>
            {secondaryButtonText}
          </CosmicButton>
        </div>
      </div>
      <div class="hero-image-container">
        <img
          src={image}
          alt={imageAlt}
          class="hero-image"
        />
      </div>
    </div>
  </div>
</section>
