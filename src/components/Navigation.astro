---
import HoverButton from './HoverButton.astro'
import NavHeader from './ui/nav-header'
---

<header class="flex flex-wrap sm:justify-start sm:flex-nowrap w-full py-3 backdrop-blur-md border-b border-white/5 sticky top-0 z-50 bg-black/20">
  <nav class="max-w-[85rem] w-full mx-auto px-4 flex flex-wrap basis-full items-center justify-between gap-4">
    <!-- Brand/Logo -->
    <a class="sm:order-1 flex-none text-xl font-semibold text-white focus:outline-none focus:opacity-80 hover:opacity-90 transition-opacity" href="/">
      <img src="https://autosvelacruz.es/wp-content/uploads/2025/10/Velacruz-Logo1.jpg" alt="AUTOS VELACRUZ" class="h-12 w-auto object-contain" />
    </a>

    <!-- Premium Navigation Header -->
    <div class="sm:order-2 flex-grow flex justify-center">
      <NavHeader client:load />
    </div>

    <!-- Mobile Toggle & Contact Button -->
    <div class="sm:order-3 flex items-center gap-x-2">
      <div class="hidden sm:block">
        <HoverButton href="/contacto" containerClass="h-10" className="px-4 py-2 text-sm">
          Contacto
        </HoverButton>
      </div>
    </div>
  </nav>
</header>
