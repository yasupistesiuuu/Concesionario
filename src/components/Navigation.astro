---
import HoverButton from './HoverButton.astro'
import NavHeader from './ui/nav-header'
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-4 px-4 w-full">
  <nav class="flex items-center justify-between gap-6 w-full max-w-6xl rounded-full border border-white/10 bg-black/30 backdrop-blur-md px-6 py-3 shadow-[0_8px_32px_rgba(0,0,0,0.5)]">
    <!-- Brand/Logo -->
    <a class="flex-none font-bold text-white focus:outline-none focus:opacity-80 hover:opacity-90 transition-opacity" href="/">
      <img src="https://autosvelacruz.es/wp-content/uploads/2025/10/Velacruz-Logo1.jpg" alt="AUTOS VELACRUZ" class="h-10 w-auto object-contain invert brightness-0 filter" />
    </a>

    <!-- Premium Navigation Header (Pill Menu) -->
    <div class="flex-grow flex justify-center">
      <NavHeader client:load />
    </div>

    <!-- Contact Button -->
    <div class="flex items-center">
      <HoverButton href="/contacto" containerClass="h-10" className="px-4 py-2 text-sm">
        Contacto
      </HoverButton>
    </div>
  </nav>
</header>
